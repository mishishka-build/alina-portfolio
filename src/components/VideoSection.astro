---
interface VideoItem {
  title: string;
  youtubeId: string;
}

interface Props {
  type: 'video-single' | 'video-row' | 'video-with-images';
  layout?: string;
  title?: string;
  subtitle?: string;
  youtubeId?: string;
  items?: VideoItem[];
  imageFolder?: string;
  images?: Array<string | { image?: string }>;
  gridColumns?: number;
}

const {
  type,
  layout,
  title,
  subtitle,
  youtubeId,
  items,
  imageFolder = '',
  images = [],
  gridColumns = 2,
} = Astro.props;

const colsClass = gridColumns === 3 ? 'cols-3' : 'cols-2';

const resolveImageSrc = (image: string | { image?: string }) => {
  const value = typeof image === 'string' ? image : image?.image || '';
  return value.startsWith('/') ? value : `${imageFolder}${value}`;
};

// Mosaic image slot assignments (by index in images array):
// [0] center-sq   C3/R1
// [1] portrait-1  C1/R2
// [2] bw-sleep    C2/R2
// [3] portrait-2  C1/R3
// [4] bw-logs     C2/R3
// [5] bonnet      C3/R4
// [6] right panel cell 1 (more cells can be added as images are available)
---

{type === 'video-single' && (
  <section class="video-section" id={title?.toLowerCase().replace(/\s+/g, '-')}>
    {title && <h2 class="section-title-medium">{title}</h2>}
    <div class="video-embed">
      <iframe
        src={`https://www.youtube.com/embed/${youtubeId}`}
        title={title}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </section>
)}

{type === 'video-row' && (
  <section class="video-row-section">
    <div class="two-col" style="display:grid; grid-template-columns: 1fr 1fr; gap: 24px;">
      {items?.map((item) => (
        <div>
          <h2 class="section-title-medium">{item.title}</h2>
          <div class="video-embed">
            <iframe
              src={`https://www.youtube.com/embed/${item.youtubeId}`}
              title={item.title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      ))}
    </div>
  </section>
)}

{type === 'video-with-images' && layout === 'mosaic' && (
  <section class="video-images-section" id={title?.toLowerCase().replace(/\s+/g, '-')}>
    <h2 class="section-title-medium">{title}</h2>
    {subtitle && <p class="section-subtitle">{subtitle}</p>}

    <div class="ym-grid">

      {/* C1+C2 / R1 — main video */}
      <div class="ym-video">
        {youtubeId ? (
          <iframe
            src={`https://www.youtube.com/embed/${youtubeId}`}
            title={title}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        ) : (
          <div class="ym-placeholder"></div>
        )}
      </div>

      {/* C3 / R1 — center square */}
      <div class="ym-center-sq">
        {images[0] && <img src={resolveImageSrc(images[0])} alt={title} loading="lazy" />}
      </div>

      {/* C1 / R2 — portrait 1 */}
      <div class="ym-portrait-1">
        {images[1] && <img src={resolveImageSrc(images[1])} alt={title} loading="lazy" />}
      </div>

      {/* C2 / R2 — B&W sleeper */}
      <div class="ym-bw-sleep">
        {images[2] && <img src={resolveImageSrc(images[2])} alt={title} loading="lazy" />}
      </div>

      {/* C3 / R2+R3 — dark video (tall) */}
      <div class="ym-dark-vid">
        <div class="ym-placeholder"></div>
      </div>

      {/* C1 / R3 — portrait 2 */}
      <div class="ym-portrait-2">
        {images[3] && <img src={resolveImageSrc(images[3])} alt={title} loading="lazy" />}
      </div>

      {/* C2 / R3 — B&W logs */}
      <div class="ym-bw-logs">
        {images[4] && <img src={resolveImageSrc(images[4])} alt={title} loading="lazy" />}
      </div>

      {/* C3 / R4 — bonnet portrait */}
      <div class="ym-bonnet">
        {images[5] && <img src={resolveImageSrc(images[5])} alt={title} loading="lazy" />}
      </div>

      {/* C4 / R1-R4 — right panel (nested 3×2 tight grid) */}
      <div class="ym-right-panel">
        {images[6] && <img src={resolveImageSrc(images[6])} alt={title} loading="lazy" />}
        <div class="ym-placeholder"></div>
        <div class="ym-placeholder"></div>
        <div class="ym-placeholder"></div>
        <div class="ym-placeholder"></div>
        <div class="ym-placeholder"></div>
      </div>

    </div>
  </section>
)}

{type === 'video-with-images' && layout !== 'mosaic' && (
  <section class="video-images-section" id={title?.toLowerCase().replace(/\s+/g, '-')}>
    <h2 class="section-title-medium">{title}</h2>
    {subtitle && <p class="section-subtitle">{subtitle}</p>}
    {youtubeId && (
      <div class="video-embed">
        <iframe
          src={`https://www.youtube.com/embed/${youtubeId}`}
          title={title}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    )}
    {images && images.length > 0 && (
      <div class={`image-grid ${colsClass}`}>
        {images.map((img) => (
          <img src={resolveImageSrc(img)} alt={title} loading="lazy" />
        ))}
      </div>
    )}
  </section>
)}

<style>
  .video-section,
  .video-row-section,
  .video-images-section {
    margin-bottom: 48px;
  }

  /* ===== MOSAIC GRID (Yana Maron) ===== */

  .ym-grid {
    display: grid;
    grid-template-columns: 160px 285px 175px 395px;
    grid-template-rows: 200px 185px 185px 175px;
    column-gap: 8px;
    row-gap: 8px;
  }

  /* shared: all images/iframes fill their cell */
  .ym-grid img,
  .ym-grid iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border: 0;
  }

  .ym-placeholder {
    width: 100%;
    height: 100%;
    background: #e0e0e0;
  }

  /* C1+C2, R1 */
  .ym-video       { grid-column: 1 / 3; grid-row: 1; overflow: hidden; }

  /* C3, R1 */
  .ym-center-sq   { grid-column: 3;     grid-row: 1; overflow: hidden; }

  /* C1, R2 */
  .ym-portrait-1  { grid-column: 1;     grid-row: 2; overflow: hidden; }

  /* C2, R2 */
  .ym-bw-sleep    { grid-column: 2;     grid-row: 2; overflow: hidden; }

  /* C3, R2+R3 */
  .ym-dark-vid    { grid-column: 3;     grid-row: 2 / 4; overflow: hidden; }

  /* C1, R3 */
  .ym-portrait-2  { grid-column: 1;     grid-row: 3; overflow: hidden; }

  /* C2, R3 */
  .ym-bw-logs     { grid-column: 2;     grid-row: 3; overflow: hidden; }

  /* C3, R4 */
  .ym-bonnet      { grid-column: 3;     grid-row: 4; overflow: hidden; }

  /* C4, R1-R4 — nested tight 3×2 */
  .ym-right-panel {
    grid-column: 4;
    grid-row: 1 / 5;
    margin-left: 12px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr 1fr;
    gap: 3px;
    overflow: hidden;
  }

  .ym-right-panel img,
  .ym-right-panel .ym-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
