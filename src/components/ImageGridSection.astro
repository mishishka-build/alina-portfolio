---
interface Props {
  id: string;
  title: string;
  titleSize?: string;
  subtitle?: string;
  columns: number;
  layout?: string;
  rowHeight?: number;
  imageFolder?: string;
  images: Array<string | { image?: string }>;
}

const {
  id,
  title,
  titleSize = 'large',
  subtitle,
  columns,
  layout = 'grid',
  rowHeight = 220,
  imageFolder = '',
  images,
} = Astro.props;

const titleClass =
  titleSize === 'large' ? 'section-title-large' :
  titleSize === 'medium' ? 'section-title-medium' :
  titleSize === 'small' ? 'section-title-small' : '';

const colsClass =
  columns === 2 ? 'cols-2' :
  columns === 3 ? 'cols-3' : 'cols-4';

const resolveImageSrc = (image: string | { image?: string }) => {
  const value = typeof image === 'string' ? image : image?.image || '';
  return value.startsWith('/') ? value : `${imageFolder}${value}`;
};
---
<section class="image-grid-section" id={id}>
  {title && <h2 class={titleClass}>{title}</h2>}
  {subtitle && <p class="section-subtitle">{subtitle}</p>}
  {layout === 'inline' ? (
    <div class="image-inline" style={`--row-height: ${rowHeight}px`}>
      {images.map((img) => (
        <img src={resolveImageSrc(img)} alt={title} loading="lazy" />
      ))}
    </div>
  ) : (
    <div class={`image-grid ${colsClass}`}>
      {images.map((img) => (
        <img src={resolveImageSrc(img)} alt={title} loading="lazy" />
      ))}
    </div>
  )}
</section>

<style>
  .image-grid-section {
    margin-bottom: 48px;
  }

  .image-inline {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .image-inline img {
    height: var(--row-height, 220px);
    width: auto;
    flex-grow: 1;
    object-fit: cover;
  }
</style>