---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Imbue:opsz,wght@10..100,400&family=Inter:wght@400;700;900&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --blue: rgb(22, 71, 217);
      --dark: rgb(34, 34, 34);
      --white: #ffffff;
      --max-width: 1024px;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--white);
      color: var(--dark);
      -webkit-font-smoothing: antialiased;
    }

    .page-wrapper {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 20px;
    }

    img {
      display: block;
      width: 100%;
      height: auto;
    }

    /* ---- Section heading styles ---- */
    .section-title-large {
      font-family: 'Inter', sans-serif;
      font-size: clamp(48px, 6vw, 78px);
      font-weight: 900;
      color: var(--blue);
      text-transform: uppercase;
      margin-bottom: 24px;
    }

    .section-title-medium {
      font-family: 'Inter', sans-serif;
      font-size: clamp(32px, 4vw, 56px);
      font-weight: 900;
      color: var(--blue);
      text-transform: uppercase;
      margin-bottom: 24px;
    }

    .section-title-small {
      font-family: 'Inter', sans-serif;
      font-size: clamp(22px, 2.5vw, 29px);
      font-weight: 700;
      color: var(--blue);
      text-transform: uppercase;
      margin-bottom: 16px;
    }

    .section-category {
      font-family: 'Imbue', serif;
      font-size: clamp(28px, 3.5vw, 41px);
      font-style: italic;
      color: var(--blue);
      text-transform: uppercase;
    }

    .section-subtitle {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 700;
      color: var(--blue);
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    /* ---- Grid layouts ---- */
    .image-grid {
      display: grid;
      gap: 4px;
    }

    .image-grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
    .image-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
    .image-grid.cols-4 { grid-template-columns: repeat(4, 1fr); }

    .image-grid img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* ---- Divider ---- */
    .section-divider {
      display: flex;
      align-items: center;
      gap: 16px;
      margin: 48px 0 32px;
    }

    .section-divider .line {
      flex: 1;
      height: 3px;
      background: var(--blue);
    }

    /* ---- Video embed ---- */
    .video-embed {
      position: relative;
      padding-bottom: 56.25%;
      height: 0;
      overflow: hidden;
      border-radius: 0;
      margin-bottom: 16px;
    }

    .video-embed iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }

    /* ---- Slideshow ---- */
    .slideshow {
      position: relative;
      overflow: hidden;
      margin-bottom: 16px;
    }

    .slideshow-track {
      display: flex;
      transition: transform 0.5s cubic-bezier(0.4, 0.24, 0.4, 1);
    }

    .slideshow-track img {
      flex: 0 0 100%;
      width: 100%;
      object-fit: cover;
    }

    .slideshow-controls {
      position: absolute;
      top: 50%;
      left: 0;
      right: 0;
      display: flex;
      justify-content: space-between;
      transform: translateY(-50%);
      padding: 0 8px;
      pointer-events: none;
    }

    .slideshow-controls button {
      pointer-events: auto;
      background: rgba(255,255,255,0.7);
      border: none;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .slideshow-counter {
      position: absolute;
      top: 12px;
      left: 12px;
      background: rgba(0,0,0,0.5);
      color: white;
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 13px;
    }

    /* ---- Responsive ---- */
    @media (max-width: 768px) {
      .image-grid.cols-4 { grid-template-columns: repeat(2, 1fr); }
      .image-grid.cols-3 { grid-template-columns: repeat(2, 1fr); }
      .hero-layout { flex-direction: column; }
      .hero-layout .hero-photo { max-width: 280px; }
      .two-col { grid-template-columns: 1fr !important; }
    }

    @media (max-width: 480px) {
      .image-grid.cols-4 { grid-template-columns: 1fr 1fr; }
      .image-grid.cols-2 { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="page-wrapper">
    <slot />
  </div>
</body>
</html>